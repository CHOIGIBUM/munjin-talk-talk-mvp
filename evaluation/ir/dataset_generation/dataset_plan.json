{
  "version": "ir-generation-v2",
  "scope": {
    "task": "symptom_ir",
    "included_questions": [
      {"visit_type": "초진", "question_id": "Q1", "meaning": "chief_complaint"},
      {"visit_type": "재진", "question_id": "Q3", "meaning": "followup_course"}
    ],
    "excluded_questions": [
      {"question_id": "Q2", "reason": "onset/timing extraction should be evaluated separately"},
      {"question_id": "Q4", "reason": "patient agenda/intent should be evaluated separately"}
    ]
  },
  "splits": {
    "train_100": {
      "count": 100,
      "purpose": "derive and review alias/few-shot/domain proposals",
      "allowed_for_tuning": true,
      "locked": false
    },
    "test_1000": {
      "count": 1000,
      "purpose": "one-time locked evaluation after train-derived changes are frozen",
      "allowed_for_tuning": false,
      "locked": true
    }
  },
  "distribution": {
    "visit_question": {
      "train_100": {
        "초진_Q1": 50,
        "재진_Q3": 50
      },
      "test_1000": {
        "초진_Q1": 500,
        "재진_Q3": 500
      }
    },
    "language_style": {
      "train_100": {
        "standard_colloquial": 50,
        "kangwon_colloquial": 50
      },
      "test_1000": {
        "standard_colloquial": 500,
        "kangwon_colloquial": 500
      }
    },
    "difficulty": {
      "easy": 0.3,
      "medium": 0.5,
      "hard": 0.2
    },
    "symptom_count_per_case": {
      "single_symptom": 0.7,
      "two_symptoms": 0.25,
      "three_symptoms": 0.05
    }
  },
  "leakage_rules": {
    "train_to_test_text_reuse": "forbidden",
    "test_failure_based_tuning": "forbidden",
    "exact_standard_label_in_direct_label_forbidden_cases": "forbidden",
    "formal_emr_style_patient_text": "forbidden"
  }
}
